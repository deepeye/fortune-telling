<view class="container">
  <view class="fortune-section" wx:if="{{profile}}">
    <view class="header-row">
      <text class="section-title">今日运势</text>
      <view class="settings-link" bindtap="goToSettings">
        <text class="settings-text">设置</text>
      </view>
    </view>

    <view class="fortune-tip">
      <text class="tip-text">{{fortune.fortuneTip}}</text>
    </view>

    <view class="dimensions">
      <view class="dimension-card">
        <text class="dimension-label">事业运</text>
        <view class="stars">{{stars.career}}</view>
      </view>
      <view class="dimension-card">
        <text class="dimension-label">财运</text>
        <view class="stars">{{stars.wealth}}</view>
      </view>
      <view class="dimension-card">
        <text class="dimension-label">健康运</text>
        <view class="stars">{{stars.health}}</view>
      </view>
      <view class="dimension-card">
        <text class="dimension-label">感情运</text>
        <view class="stars">{{stars.love}}</view>
      </view>
    </view>

    <view class="preview-section">
      <text class="section-subtitle">深度解读</text>

      <view class="preview-card" bindtap="onPreviewTap">
        <text class="preview-title">事业运解读</text>
        <view class="preview-content">
          <text class="preview-text">完整事业运分析</text>
        </view>
      </view>

      <view class="preview-card" bindtap="onPreviewTap">
        <text class="preview-title">财运解读</text>
        <view class="preview-content">
          <text class="preview-text">完整财运分析</text>
        </view>
      </view>

      <view class="preview-card" bindtap="onPreviewTap">
        <text class="preview-title">健康运解读</text>
        <view class="preview-content">
          <text class="preview-text">完整健康运分析</text>
        </view>
      </view>

      <view class="preview-card" bindtap="onPreviewTap">
        <text class="preview-title">感情运解读</text>
        <view class="preview-content">
          <text class="preview-text">完整感情运分析</text>
        </view>
      </view>
    </view>

    <view class="pillars-section">
      <text class="section-subtitle">命盘</text>

      <view class="pillars-table">
        <view class="pillar-row header-row">
          <text class="pillar-cell"></text>
          <text class="pillar-cell">年柱</text>
          <text class="pillar-cell">月柱</text>
          <text class="pillar-cell">日柱</text>
          <text class="pillar-cell">时柱</text>
        </view>
        <view class="pillar-row">
          <text class="pillar-cell label-cell">天干</text>
          <text class="pillar-cell">{{profile.yearPillar.stem}}</text>
          <text class="pillar-cell">{{profile.monthPillar.stem}}</text>
          <text class="pillar-cell">{{profile.dayPillar.stem}}</text>
          <text class="pillar-cell">{{profile.hourPillar.stem}}</text>
        </view>
        <view class="pillar-row">
          <text class="pillar-cell label-cell">地支</text>
          <text class="pillar-cell">{{profile.yearPillar.branch}}</text>
          <text class="pillar-cell">{{profile.monthPillar.branch}}</text>
          <text class="pillar-cell">{{profile.dayPillar.branch}}</text>
          <text class="pillar-cell">{{profile.hourPillar.branch}}</text>
        </view>
      </view>

      <text class="estimated-note" wx:if="{{profile.isHourEstimated}}">时辰为估算，结果仅供参考</text>
    </view>

    <view class="share-section">
      <view class="share-btn" bindtap="onShare">
        <text class="share-text">分享运势海报</text>
      </view>
    </view>
  </view>

  <canvas canvas-id="posterCanvas" class="poster-canvas" style="width: 600px; height: 800px;"></canvas>

  <view class="empty-state" wx:if="{{!profile}}">
    <text class="empty-text">请先输入出生信息</text>
    <view class="go-input-btn" bindtap="goToInput">
      <text class="go-input-text">开始测算</text>
    </view>
  </view>
</view>