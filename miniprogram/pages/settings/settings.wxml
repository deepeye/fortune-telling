<view class="container">
  <view class="settings-section">
    <text class="section-title">设置</text>

    <view class="setting-card">
      <text class="setting-label">修改出生信息</text>
      <view class="setting-row">
        <text class="setting-desc">当前：{{currentBirthDate}} {{currentShichen}}</text>
        <view class="setting-btn" bindtap="goToEditBirth">
          <text class="btn-text">修改</text>
        </view>
      </view>
    </view>

    <view class="setting-card">
      <text class="setting-label">隐私政策</text>
      <view class="setting-row">
        <text class="setting-desc">查看数据收集与使用说明</text>
        <view class="setting-btn" bindtap="goToPrivacy">
          <text class="btn-text">查看</text>
        </view>
      </view>
    </view>

    <view class="setting-card danger-card">
      <text class="setting-label danger-label">删除我的数据</text>
      <view class="setting-row">
        <text class="setting-desc danger-desc">一键删除所有个人信息，不可恢复</text>
        <view class="setting-btn danger-btn" bindtap="onDeleteData">
          <text class="btn-text danger-text">删除</text>
        </view>
      </view>
    </view>
  </view>
</view>