.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  background-color: #f5f0e8;
}

.policy-section {
  background-color: #faf7f0;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #2c2c2c;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.section-content {
  font-size: 24rpx;
  color: #666;
  display: block;
  line-height: 1.8;
}