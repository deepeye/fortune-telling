.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  background-color: #f5f0e8;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #2c2c2c;
  display: block;
  letter-spacing: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #8b7355;
  display: block;
  margin-top: 16rpx;
}

.calendar-type-switch {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  padding: 0 20rpx;
}

.switch-label {
  font-size: 28rpx;
  color: #8b7355;
  margin-right: 20rpx;
}

.switch-tabs {
  display: flex;
  border: 1rpx solid #8b7355;
  border-radius: 8rpx;
}

.tab {
  padding: 12rpx 32rpx;
  font-size: 28rpx;
  color: #8b7355;
}

.tab-active {
  background-color: #8b7355;
  color: #f5f0e8;
}

.form-section {
  margin-bottom: 40rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  background-color: #faf7f0;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 28rpx;
  color: #2c2c2c;
}

.picker-value {
  font-size: 28rpx;
  color: #8b7355;
  text-align: right;
}

.uncertain-row {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
}

.uncertain-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 16rpx;
}

.uncertain-hint {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.submit-btn {
  margin-top: 60rpx;
  padding: 32rpx;
  background-color: #8b7355;
  border-radius: 12rpx;
  text-align: center;
}

.submit-text {
  font-size: 32rpx;
  color: #f5f0e8;
  letter-spacing: 8rpx;
}